rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function authEmail() {
      return (isSignedIn() && request.auth.token.email is string)
        ? request.auth.token.email
        : '';
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/super_admins/$(uid())) &&
        (
          !('status' in get(/databases/$(database)/documents/super_admins/$(uid())).data) ||
          get(/databases/$(database)/documents/super_admins/$(uid())).data.status == 'active' ||
          get(/databases/$(database)/documents/super_admins/$(uid())).data.status == 'Active' ||
          get(/databases/$(database)/documents/super_admins/$(uid())).data.status == 'ACTIVE'
        );
    }

    function hasUserTenantLink() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/user_tenant/$(uid()));
    }

    function userTenantId() {
      return hasUserTenantLink()
        ? get(/databases/$(database)/documents/user_tenant/$(uid())).data.tenantId
        : null;
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && userTenantId() == tenantId;
    }

    function isSelfWorkspaceOwner(tenantId) {
      return isSignedIn() && tenantId == uid();
    }

    function tenantExists(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function tenantIsActive(tenantId) {
      return tenantExists(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == 'active';
    }

    function requesterTenantUserExists(tenantId) {
      return isTenantMember(tenantId) &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid()));
    }

    function requesterTenantRole(tenantId) {
      return requesterTenantUserExists(tenantId)
        ? get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid())).data.role
        : '';
    }

    function requesterTenantDisplayName(tenantId) {
      return requesterTenantUserExists(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid())).data.displayName is string
        ? get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid())).data.displayName
        : '';
    }

    function requesterTenantUserIsActive(tenantId) {
      return requesterTenantUserExists(tenantId) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid())).data.status == 'active';
    }

    function requesterIsTenantAdmin(tenantId) {
      return requesterTenantRole(tenantId) == 'admin';
    }

    function tenantHasModule(tenantId, moduleKey) {
      return tenantExists(tenantId) &&
        moduleKey in get(/databases/$(database)/documents/tenants/$(tenantId)).data.modules;
    }

    function requesterHasModule(tenantId, moduleKey) {
      return requesterTenantUserIsActive(tenantId) &&
        tenantIsActive(tenantId) &&
        tenantHasModule(tenantId, moduleKey) &&
        moduleKey in get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(uid())).data.activeModules;
    }

    function requesterCanEditRecetario(tenantId) {
      return requesterTenantRole(tenantId) in ['admin', 'engineer'];
    }

    function isAnnulledOrderStatus(status) {
      return status in ['annulled', 'anulado', 'cancelled'];
    }

    function operatorCanUpdateOwnOrderExecution(tenantId) {
      return requesterHasModule(tenantId, 'recetario_agronomico') &&
        requesterTenantRole(tenantId) == 'operator' &&
        (
          resource.data.assignedToUid == uid() ||
          (
            resource.data.operatorName is string &&
            requesterTenantDisplayName(tenantId) != '' &&
            resource.data.operatorName == requesterTenantDisplayName(tenantId)
          )
        ) &&
        request.resource.data.assignedToUid == resource.data.assignedToUid &&
        !isAnnulledOrderStatus(resource.data.status) &&
        request.resource.data.status in ['pending', 'completed'] &&
        request.resource.data.updatedBy == uid() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'execution',
          'updatedBy',
          'updatedAt',
        ]) &&
        request.resource.data.execution is map &&
        request.resource.data.execution.operatorUid == uid() &&
        request.resource.data.execution.diff(resource.data.execution).changedKeys().hasOnly([
          'done',
          'doneAt',
          'operatorUid',
          'appliedTankCount',
          'appliedVolumeLt',
          'tankApplications',
        ]);
    }

    function hasOnboardingInviteCodeInRequest() {
      return ('onboardingInviteCode' in request.resource.data) &&
        (request.resource.data.onboardingInviteCode is string);
    }

    function inviteExists(inviteCode) {
      return inviteCode is string &&
        exists(/databases/$(database)/documents/tenant_user_invites/$(inviteCode));
    }

    function invite(inviteCode) {
      return get(/databases/$(database)/documents/tenant_user_invites/$(inviteCode)).data;
    }

    function inviteAfter(inviteCode) {
      return getAfter(/databases/$(database)/documents/tenant_user_invites/$(inviteCode)).data;
    }

    function inviteBelongsToAuth(inviteCode) {
      return inviteExists(inviteCode) &&
        authEmail() != '' &&
        (invite(inviteCode).emailLower == authEmail() || invite(inviteCode).email == authEmail());
    }

    function inviteIsNotExpired(inviteCode) {
      return !('expiresAt' in invite(inviteCode)) ||
        invite(inviteCode).expiresAt == null ||
        invite(inviteCode).expiresAt > request.time;
    }

    function inviteReadableByUser(inviteCode) {
      return inviteBelongsToAuth(inviteCode) &&
        invite(inviteCode).inviteState == 'pending' &&
        inviteIsNotExpired(inviteCode);
    }

    function canClaimInvite(inviteCode) {
      return inviteReadableByUser(inviteCode) &&
        request.resource.data.inviteState == 'claimed' &&
        request.resource.data.claimedByUid == uid() &&
        request.resource.data.inviteCode == invite(inviteCode).inviteCode &&
        request.resource.data.tenantId == invite(inviteCode).tenantId &&
        request.resource.data.emailLower == invite(inviteCode).emailLower &&
        request.resource.data.role == invite(inviteCode).role &&
        request.resource.data.status == invite(inviteCode).status &&
        request.resource.data.activeModules == invite(inviteCode).activeModules &&
        request.resource.data.displayName == invite(inviteCode).displayName;
    }

    function inviteClaimMatchesRequest(inviteCode, tenantId) {
      return inviteExists(inviteCode) &&
        authEmail() != '' &&
        inviteAfter(inviteCode).inviteState == 'claimed' &&
        inviteAfter(inviteCode).claimedByUid == uid() &&
        inviteAfter(inviteCode).tenantId == tenantId &&
        (inviteAfter(inviteCode).emailLower == authEmail() || inviteAfter(inviteCode).email == authEmail());
    }

    function inviteClaimMatchesTenantUserRequest(tenantId) {
      return hasOnboardingInviteCodeInRequest() &&
        inviteClaimMatchesRequest(request.resource.data.onboardingInviteCode, tenantId) &&
        request.resource.data.role == inviteAfter(request.resource.data.onboardingInviteCode).role &&
        request.resource.data.status == inviteAfter(request.resource.data.onboardingInviteCode).status &&
        request.resource.data.activeModules == inviteAfter(request.resource.data.onboardingInviteCode).activeModules &&
        request.resource.data.displayName == inviteAfter(request.resource.data.onboardingInviteCode).displayName;
    }

    function authEmailIndexTenantIdIsValid() {
      return !('tenantId' in request.resource.data) ||
        request.resource.data.tenantId == null ||
        (hasUserTenantLink() &&
          request.resource.data.tenantId is string &&
          request.resource.data.tenantId == userTenantId());
    }

    function authEmailIndexPasswordResetAllowedIsValid() {
      return !('passwordResetAllowed' in request.resource.data) ||
        request.resource.data.passwordResetAllowed == null ||
        (hasUserTenantLink() &&
          request.resource.data.passwordResetAllowed is bool &&
          request.resource.data.passwordResetAllowed == (userTenantId() != uid()));
    }

    function canCreateSelfTenantLinkFromExistingMembership(userId) {
      return isSignedIn() &&
        userId == uid() &&
        !exists(/databases/$(database)/documents/user_tenant/$(userId)) &&
        canWriteSelfTenantLinkFromExistingMembership(userId);
    }

    function canWriteSelfTenantLinkFromExistingMembership(userId) {
      return isSignedIn() &&
        userId == uid() &&
        request.resource.data.tenantId is string &&
        request.resource.data.displayName is string &&
        request.resource.data.createdAt is timestamp &&
        exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/users/$(userId)) &&
        get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/users/$(userId)).data.displayName ==
          request.resource.data.displayName;
    }

    match /super_admins/{superUid} {
      allow read: if isSuperAdmin() || (isSignedIn() && superUid == uid());
      allow create, update, delete: if isSuperAdmin();
    }

    match /system_config/{configId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isSuperAdmin() && configId == 'support';
    }

    match /auth_email_index/{emailLower} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isSignedIn() &&
        request.resource.data.uid == uid() &&
        request.resource.data.email == authEmail() &&
        request.resource.data.emailLower == emailLower &&
        authEmailIndexTenantIdIsValid() &&
        authEmailIndexPasswordResetAllowedIsValid();
      allow delete: if isSuperAdmin();
    }

    match /tenant_user_invites/{inviteCode} {
      allow read: if isSuperAdmin() || inviteReadableByUser(inviteCode);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || canClaimInvite(inviteCode);
    }

    match /user_tenant/{userId} {
      allow read: if isSuperAdmin() || (isSignedIn() && userId == uid());
      allow create: if isSuperAdmin() ||
        (isSignedIn() &&
          userId == uid() &&
          !exists(/databases/$(database)/documents/user_tenant/$(userId)) &&
          request.resource.data.tenantId == uid() &&
          request.resource.data.displayName is string &&
          request.resource.data.createdAt is timestamp) ||
        (isSignedIn() &&
          userId == uid() &&
          !exists(/databases/$(database)/documents/user_tenant/$(userId)) &&
          request.resource.data.tenantId is string &&
          request.resource.data.displayName is string &&
          hasOnboardingInviteCodeInRequest() &&
          request.resource.data.displayName ==
            inviteAfter(request.resource.data.onboardingInviteCode).displayName &&
          inviteClaimMatchesRequest(
            request.resource.data.onboardingInviteCode,
            request.resource.data.tenantId
          )) ||
        canCreateSelfTenantLinkFromExistingMembership(userId);
      allow update: if isSuperAdmin() ||
        (isSignedIn() &&
          userId == uid() &&
          resource.data.tenantId == uid() &&
          request.resource.data.tenantId == resource.data.tenantId &&
          request.resource.data.createdAt == resource.data.createdAt) ||
        canWriteSelfTenantLinkFromExistingMembership(userId);
      allow delete: if isSuperAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || isTenantMember(tenantId);
      allow create: if isSuperAdmin() ||
        (isSelfWorkspaceOwner(tenantId) &&
          request.resource.data.createdBy == uid() &&
          request.resource.data.status == 'active' &&
          request.resource.data.modules is list);
      allow update: if isSuperAdmin() || isSelfWorkspaceOwner(tenantId);
      allow delete: if isSuperAdmin();

      match /users/{userId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId) ||
          (isSignedIn() && userId == uid());
        allow create, update, delete: if isSuperAdmin() ||
          (isSelfWorkspaceOwner(tenantId) && userId == uid()) ||
          (tenantIsActive(tenantId) && requesterIsTenantAdmin(tenantId)) ||
          (isSignedIn() && userId == uid() && inviteClaimMatchesTenantUserRequest(tenantId));
      }

      match /recipes/{recipeId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, update, delete: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
      }

      match /application_orders/{orderId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, delete: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
        allow update: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId)) ||
          operatorCanUpdateOwnOrderExecution(tenantId);
      }

      match /counters/{counterId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, update: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
        allow delete: if isSuperAdmin();
      }

      match /fields/{fieldId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, update, delete: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
      }

      match /inputs/{inputId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, update, delete: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
      }

      match /operators/{operatorId} {
        allow read: if isSuperAdmin() || requesterHasModule(tenantId, 'recetario_agronomico');
        allow create, update, delete: if isSuperAdmin() ||
          (requesterHasModule(tenantId, 'recetario_agronomico') && requesterCanEditRecetario(tenantId));
      }

      match /{document=**} {
        allow read, write: if isSuperAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
